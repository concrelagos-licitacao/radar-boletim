# Template de secrets para Streamlit Cloud.
# Em deploy: vá em https://share.streamlit.io/, selecione o app,
# Settings → Secrets, cole o conteúdo abaixo preenchido.
# NÃO COMITE secrets.toml com valores reais.

[auth]
password = "TROQUE_POR_SENHA_FORTE"

[gcp]
sheets_id = "13R-89b7f0SOaYlrHziKTxhIipXi-VVuFaLF6sIQQtk4"

# Service Account JSON (cole o conteúdo do arquivo credenciais/service_account.json
# como subtabela [gcp.service_account]).
[gcp.service_account]
type = "service_account"
project_id = "concrelagos-hub"
private_key_id = "..."
private_key = """-----BEGIN PRIVATE KEY-----
MII...
-----END PRIVATE KEY-----
"""
client_email = "scraper-bot@concrelagos-hub.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"

# =========================================================================
# Resumo com IA — Google Gemini API (GRATUITO)
# Obtenha em: https://aistudio.google.com/app/apikey
# Selecione o projeto concrelagos-hub → Create API key
# =========================================================================
[gemini]
api_key = "AIza..."

# =========================================================================
