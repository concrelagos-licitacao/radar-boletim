# =========================================================================
# Concrelagos Intelligence Hub — Variáveis de ambiente
# Copie este arquivo para `.env` e preencha. NUNCA comite o `.env`.
# =========================================================================

# API key do Google Maps (Distance Matrix + Geocoding)
GOOGLE_MAPS_API_KEY=

# ID da planilha "Concrelagos Hub" (na URL: docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SHEETS_ID=

# Caminho para o JSON da Service Account
GOOGLE_SHEETS_CREDENTIALS_PATH=./credenciais/service_account.json

# Janela de dias para buscar editais no PNCP (D-N até hoje). Padrão: 1.
JANELA_DIAS=1

# =========================================================================
# Notificações por e-mail (opcional)
# Crie uma "Senha de app" Gmail em myaccount.google.com/apppasswords
# =========================================================================
NOTIFICACAO_EMAIL_DE=
NOTIFICACAO_EMAIL_SENHA=
NOTIFICACAO_EMAIL_PARA=licitacao.concrelagos@gmail.com

# =========================================================================
# Resumo com IA — Claude API (opcional)
# Obtenha em console.anthropic.com → API Keys
# =========================================================================
ANTHROPIC_API_KEY=
